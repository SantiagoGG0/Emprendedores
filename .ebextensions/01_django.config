option_settings:
  aws:elasticbeanstalk:container:python:
    WSGIPath: suluhisho_platform.wsgi:application
  aws:elasticbeanstalk:application:environment:
    DJANGO_SETTINGS_MODULE: suluhisho_platform.settings.production
    PYTHONPATH: /var/app/current:$PYTHONPATH

container_commands:
  01_migrate:
    command: "source /var/app/venv/*/bin/activate && python manage.py migrate --noinput"
    leader_only: true
  02_collectstatic:
    command: "source /var/app/venv/*/bin/activate && python manage.py collectstatic --noinput"
    leader_only: true
  03_create_superuser:
    command: "source /var/app/venv/*/bin/activate && python create_superuser_prod.py"
    leader_only: true
    ignoreErrors: true
